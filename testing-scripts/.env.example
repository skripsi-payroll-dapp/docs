# Copy this file to .env and fill in real values locally.
# NEVER commit .env — it is already gitignored in this folder.

# Backend base URL (default assumes local dev server per docker-compose/PDHUPL Bab 2)
BACKEND_URL=http://localhost:3001

# Base Sepolia RPC endpoint used for on-chain reads/writes in ku-28-suspension.mjs
RPC_URL=https://sepolia.base.org

# Override only if your local .env for the app itself deploys a different PayrollFactory
# (defaults to the Gen8 address already in frontend/src/infrastructure/chain/contracts.ts)
PAYROLL_FACTORY_ADDRESS=0x73926c8abdbd2ebcc09f5e6af7def1bb3af156de

# ── Role private keys (Base Sepolia testnet ONLY — never a mainnet key) ──────────────
# Each of these must be a wallet that ALREADY has the corresponding role set up in your
# testnet environment (matching PDHUPL_v2.md Bab 2.3 material list):
#   TEST_OWNER_PRIVATE_KEY    — address must equal backend's OWNER_ADDRESS env var
#   TEST_HR_PRIVATE_KEY       — address must already have a deployed CompanyVault
#                               (PayrollFactory.companyVaults(address) != 0x0)
#   TEST_LEGAL_PRIVATE_KEY    — address must hold LEGAL_ROLE on TEST_HR's vault
#   TEST_EMPLOYEE_PRIVATE_KEY — address must have an employeeStream registered under
#                               TEST_HR's vault. For ku-28's on-chain claimSalary check this
#                               must be a plain EOA (not a Privy smart account) with a small
#                               amount of Base Sepolia ETH for gas.
TEST_OWNER_PRIVATE_KEY=
TEST_HR_PRIVATE_KEY=
TEST_LEGAL_PRIVATE_KEY=
TEST_EMPLOYEE_PRIVATE_KEY=

# A wallet you have manually suspended (or already suspended via ku-28's AU-28-01 step) —
# used only to prove a suspended HR cannot log in (AU-01-05). Can be the same key as
# TEST_HR_PRIVATE_KEY if you run ku-28 first and capture it while still suspended.
TEST_SUSPENDED_HR_PRIVATE_KEY=

# Just an address (no private key) of a second, unrelated HR — used only for the cross-HR
# forbidden checks in ku-13-compliance.mjs (AU-13-03).
TEST_HR2_ADDRESS=

# Optional — enables the happy-path (not just negative-path) checks in a couple of scripts.
# Leave blank to skip; the scripts still run and report the negative-path result instead.
TEST_REIMBURSE_APPROVE_TXHASH=
TEST_PAYSLIP_CLAIM_ID=
